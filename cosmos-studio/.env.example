# ============================================================================
# COSMOS Studio — environment template
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in. NEVER commit `.env`. In production these values
# are injected by Infisical (`infisical run -- node server/index.js`) — the
# .env file is a local-dev convenience only (pauli-secrets-vault pattern).
#
# Every variable is optional at boot: missing keys make the affected feature
# return clearly-labeled stubs instead of crashing, so you can run the whole
# pipeline dry before spending a cent.
# ============================================================================

# ---- Internal auth ---------------------------------------------------------
# Key Hermes uses for /api/brief, /api/jobs, /api/metrics. Generate:
#   openssl rand -hex 32
HERMES_API_KEY=

# Bambu-only key for POST /api/approve. Must differ from HERMES_API_KEY —
# Hermes must never hold this. Generate the same way.
PAULI_API_KEY=

# Master secret for license-lock key derivation (rotating unlock keys).
#   openssl rand -hex 32   — losing this means re-issuing all client keys.
LICENSE_MASTER_SECRET=

# ---- Generation providers --------------------------------------------------
# fal.ai — stills (FLUX 1.1 Pro Ultra) + video (Seedance 2.0/2.5/Mini).
# Get: https://fal.ai/dashboard/keys
FAL_KEY=

# Hugging Face — FLUX.1-dev image fallback + warm video models.
# Get: https://huggingface.co/settings/tokens (read scope is enough)
HF_TOKEN=

# ---- Text models -----------------------------------------------------------
# Anthropic — Fable 5 (plan/review), Sonnet (code), Haiku (QA).
# Get: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenRouter — routing layer for Grok and others, no lock-in.
# Get: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Grok direct (optional if you route Grok through OpenRouter).
# Get: https://console.x.ai
GROK_API_KEY=

# MuAPI — Fable 5 at 20% discount + Seedance 2.5 / Veo 3.1.
# Get: https://muapi.ai (dashboard → API keys)
MUAPI_KEY=

# ---- Voice -----------------------------------------------------------------
# ElevenLabs — narration + UGC character voices (Alex™ persona voices).
# Get: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ---- Payments --------------------------------------------------------------
# Stripe — primary card payments. Get: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret for /api/webhooks/payment.
# Get: https://dashboard.stripe.com/webhooks (after adding the endpoint)
STRIPE_WEBHOOK_SECRET=

# Creem.io — Stripe alternative, no monthly fee. Get: https://creem.io dashboard
CREEM_API_KEY=

# Lightning Network via LND REST — auto-proceed < $500, Bambu gate ≥ $500.
# LN_REST_URL like https://your-node:8080 ; macaroon hex-encoded (invoice perms).
LN_REST_URL=
LN_MACAROON=
LN_CERT=

# BTCPay Server — on-chain Bitcoin fallback. Get: your BTCPay instance → API keys
BTCPAY_URL=
BTCPAY_API_KEY=

# ---- Secrets vault (production) --------------------------------------------
# Infisical service token — in prod ALL of the above come through Infisical.
# Get: https://app.infisical.com → project → service tokens
INFISICAL_TOKEN=

# ---- Compute (Blender / GPU renders) ----------------------------------------
# RunPod — GPU compute, affiliate: https://runpod.io/?ref=kupuri
RUNPOD_API_KEY=
# Vast.ai — GPU fallback, affiliate: https://vast.ai/?ref=kupuri
VASTAI_API_KEY=

# ---- Automation -------------------------------------------------------------
# n8n webhook — Bambu notifications + lead nurturing. Your n8n workflow URL.
N8N_WEBHOOK_URL=

# ---- Server ------------------------------------------------------------------
PORT=3000
# Where the job store snapshots (defaults to .pauli/jobs.json inside the app).
JOB_STORE_PATH=
# Where license state lives (defaults to _config/license.json).
LICENSE_PATH=
